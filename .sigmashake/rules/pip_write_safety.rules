# pip_write_safety.rules — Enforce safe dependency pinning for Python projects.
# Technology: pip/uv | Capability: write
# Covers: requirements.txt unpinned deps, .pypirc credentials, uv.lock, pip.conf.

rule no-unpinned-requirements {
  enabled true
  priority 85
  severity error
  DENY write
  IF path EQUALS "requirements.txt" AND content LINE_REGEX "^[a-zA-Z][a-zA-Z0-9_.-]*\\s*$"
  OR path GLOB "**/requirements*.txt" AND content LINE_REGEX "^[a-zA-Z][a-zA-Z0-9_.-]*\\s*$"
  MESSAGE "Unpinned dependency in requirements.txt (no version specifier) installs whatever is latest at install time, making builds non-reproducible. Use exact pins: <package>==<version>. Generate with 'pip freeze' or 'uv pip compile'."
}

rule no-pypirc-password {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS ".pypirc" AND content LINE_REGEX "password\\s*="
  OR path GLOB "**/.pypirc" AND content LINE_REGEX "password\\s*="
  MESSAGE "Plaintext PyPI password in .pypirc exposes credentials in source control. Use API tokens instead (token = pypi-...) and store them in environment variables or a secrets manager, not in the file."
}

rule no-edit-uv-lockfile {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS "uv.lock"
  OR path ENDS_WITH "/uv.lock"
  MESSAGE "uv.lock must not be hand-edited. It is machine-generated by 'uv lock' or 'uv sync'. Manual edits corrupt the resolution graph and integrity hashes."
}

rule no-pip-conf-credentials {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS "pip.conf" AND content LINE_REGEX "(password|token)\\s*="
  OR path ENDS_WITH "/pip.conf" AND content LINE_REGEX "(password|token)\\s*="
  OR path GLOB "**/pip/pip.conf" AND content LINE_REGEX "(password|token)\\s*="
  MESSAGE "Hardcoded password or token in pip.conf exposes credentials in source control. Use environment variables (PIP_INDEX_URL with embedded credentials) or a credential helper instead."
}
